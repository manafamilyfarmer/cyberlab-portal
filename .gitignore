# Secrets — never commit
.env
*.env
secrets/
# WireGuard peer configs + manifest are bind-mounted secrets (B4.4). They live
# OUTSIDE this repo tree (host /opt/cyberlab-portal/secrets/wg on VM114); these
# patterns are belt-and-suspenders so a stray copy can never be staged.
*.conf
wg/
manifest.tsv
portal-secrets/
portal-app-secrets/
# WireGuard status SSH PRIVATE key (B4.5) — never commit. The pinned known_hosts
# under deploy/wg-status/ is the host PUBLIC key and IS committed on purpose.
id_wgstatus
wg-status/id_*
*id_wgstatus*

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Django
db.sqlite3
*.log
staticfiles/

# OS / editor
.DS_Store
.idea/
.vscode/
