# Shape only — NO real values. Real secrets live on VM114 under
# /opt/cyberlab-portal/secrets/{portaldb.env,portal-app.env} (root:root 600).

# --- portaldb.env (database, provisioned in B1 Step 1) ---
PORTAL_DB_HOST=
PORTAL_DB_PORT=
PORTAL_DB_NAME=
PORTAL_DB_USER=
PORTAL_DB_PASSWORD=
PORTAL_DB_SSLMODE=

# --- portal-app.env (Django app) ---
DJANGO_SECRET_KEY=
DJANGO_DEBUG=
DJANGO_SETTINGS_MODULE=
# Optional: gate production transport-security headers (needs TLS in front, B2)
DJANGO_SECURE=
